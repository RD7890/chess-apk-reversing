<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/topLayout"
    android:background="@drawable/bg2"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:orientation="vertical"
        android:id="@+id/titlel"
        android:background="#b4000000"
        android:padding="5dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:minHeight="63dp">
        <TextView
            android:textSize="30dp"
            android:textColor="#ffffffff"
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/set_title_top"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
    <ScrollView
        android:id="@+id/sv"
        android:scrollbars="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/btns"
        android:layout_below="@+id/titlel">
        <RelativeLayout
            android:id="@+id/inner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:id="@+id/linerThemes"
                android:background="#b4000000"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp">
                <HorizontalScrollView
                    android:id="@+id/hsv"
                    android:paddingLeft="5dp"
                    android:paddingTop="2dp"
                    android:paddingRight="5dp"
                    android:paddingBottom="2dp"
                    android:scrollbars="none"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:measureAllChildren="false"
                    android:fillViewport="true">
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@+id/innerLay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="0dp"
                        android:weightSum="1">
                        <LinearLayout
                            android:orientation="horizontal"
                            android:background="#00ff0000"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="5dp"
                            android:layout_marginRight="5dp"
                            android:layout_below="@+id/hsv">
                            <Button
                                android:textSize="15dp"
                                android:textColor="#ffffffff"
                                android:id="@+id/button_tm1"
                                android:background="#ff666666"
                                android:padding="5dp"
                                android:layout_width="130dp"
                                android:layout_height="72dp"
                                android:layout_margin="2dp"
                                android:text=""
                                android:soundEffectsEnabled="false"
                                android:onClick="tm1Clicked"/>
                        </LinearLayout>
                        <LinearLayout
                            android:orientation="horizontal"
                            android:background="#00ff0000"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="5dp"
                            android:layout_marginRight="5dp"
                            android:layout_below="@+id/hsv">
                            <Button
                                android:textSize="15dp"
                                android:textColor="#ffffffff"
                                android:id="@+id/button_tm4"
                                android:background="#ff666666"
                                android:padding="5dp"
                                android:layout_width="130dp"
                                android:layout_height="72dp"
                                android:layout_margin="2dp"
                                android:soundEffectsEnabled="false"
                                android:onClick="tm4Clicked"/>
                        </LinearLayout>
                        <LinearLayout
                            android:orientation="horizontal"
                            android:background="#00ff0000"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="5dp"
                            android:layout_marginRight="5dp"
                            android:layout_below="@+id/hsv">
                            <Button
                                android:textSize="15dp"
                                android:textColor="#ffffffff"
                                android:id="@+id/button_tm6"
                                android:background="#ff666666"
                                android:padding="5dp"
                                android:layout_width="130dp"
                                android:layout_height="72dp"
                                android:layout_margin="2dp"
                                android:text=""
                                android:soundEffectsEnabled="false"
                                android:onClick="tm6Clicked"/>
                        </LinearLayout>
                        <LinearLayout
                            android:orientation="horizontal"
                            android:background="#00ff0000"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="5dp"
                            android:layout_marginRight="5dp"
                            android:layout_below="@+id/hsv">
                            <Button
                                android:textSize="15dp"
                                android:textColor="#ffffffff"
                                android:id="@+id/button_tm8"
                                android:background="#ff666666"
                                android:padding="5dp"
                                android:layout_width="130dp"
                                android:layout_height="72dp"
                                android:layout_margin="2dp"
                                android:soundEffectsEnabled="false"
                                android:onClick="tm8Clicked"/>
                        </LinearLayout>
                        <LinearLayout
                            android:orientation="horizontal"
                            android:background="#00ff0000"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="5dp"
                            android:layout_marginRight="5dp"
                            android:layout_below="@+id/hsv">
                            <Button
                                android:textSize="15dp"
                                android:textColor="#ffffffff"
                                android:id="@+id/button_tm5"
                                android:background="#ff666666"
                                android:padding="5dp"
                                android:layout_width="130dp"
                                android:layout_height="72dp"
                                android:layout_margin="2dp"
                                android:soundEffectsEnabled="false"
                                android:onClick="tm5Clicked"/>
                        </LinearLayout>
                        <LinearLayout
                            android:orientation="horizontal"
                            android:background="#00ff0000"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="5dp"
                            android:layout_marginRight="5dp"
                            android:layout_below="@+id/hsv">
                            <Button
                                android:textSize="15dp"
                                android:textColor="#ffffffff"
                                android:id="@+id/button_tm2"
                                android:background="#ff666666"
                                android:padding="5dp"
                                android:layout_width="130dp"
                                android:layout_height="72dp"
                                android:layout_margin="2dp"
                                android:soundEffectsEnabled="false"
                                android:onClick="tm2Clicked"/>
                        </LinearLayout>
                        <LinearLayout
                            android:orientation="horizontal"
                            android:background="#00ff0000"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="5dp"
                            android:layout_marginRight="5dp"
                            android:layout_below="@+id/hsv">
                            <Button
                                android:textSize="15dp"
                                android:textColor="#ffffffff"
                                android:id="@+id/button_tm7"
                                android:background="#ff666666"
                                android:padding="5dp"
                                android:layout_width="130dp"
                                android:layout_height="72dp"
                                android:layout_margin="2dp"
                                android:soundEffectsEnabled="false"
                                android:onClick="tm7Clicked"/>
                        </LinearLayout>
                        <LinearLayout
                            android:orientation="horizontal"
                            android:background="#00ff0000"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="5dp"
                            android:layout_marginRight="5dp"
                            android:layout_below="@+id/hsv">
                            <Button
                                android:textSize="15dp"
                                android:textColor="#ffffffff"
                                android:id="@+id/button_tm3"
                                android:background="#ff666666"
                                android:padding="5dp"
                                android:layout_width="130dp"
                                android:layout_height="72dp"
                                android:layout_margin="2dp"
                                android:soundEffectsEnabled="false"
                                android:onClick="tm3Clicked"/>
                        </LinearLayout>
                    </LinearLayout>
                </HorizontalScrollView>
            </RelativeLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/hsv9"
                android:background="#8cffffff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:weightSum="4"
                android:layout_below="@+id/linerThemes"
                android:layout_centerVertical="true">
                <TextView
                    android:textSize="15dp"
                    android:textColor="#ff000000"
                    android:gravity="center"
                    android:id="@+id/tx10"
                    android:padding="10dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="10dp"
                    android:text="@string/set_rm_title"
                    android:layout_weight="2"
                    android:layout_centerHorizontal="true"/>
                <Button
                    android:textSize="13dp"
                    android:textStyle="bold"
                    android:textColor="#fffcba03"
                    android:gravity="center"
                    android:id="@+id/button_rm"
                    android:background="@drawable/xml_button_play"
                    android:padding="10dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="-10dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginRight="10dp"
                    android:layout_marginBottom="5dp"
                    android:text="@string/set_rm"
                    android:layout_weight="2"
                    android:soundEffectsEnabled="false"
                    android:onClick="rmClicked"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/hsv6"
                android:background="#8cffffff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:weightSum="4"
                android:layout_below="@+id/hsv9">
                <TextView
                    android:textSize="15dp"
                    android:textColor="#ff000000"
                    android:gravity="center"
                    android:id="@+id/tx4"
                    android:padding="10dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="10dp"
                    android:text="@string/set_view_title"
                    android:layout_weight="2"
                    android:layout_centerHorizontal="true"/>
                <Button
                    android:textSize="10dp"
                    android:textColor="#ffffffff"
                    android:gravity="center"
                    android:id="@+id/button_v2"
                    android:background="#c8000000"
                    android:padding="10dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginTop="5dp"
                    android:layout_marginRight="10dp"
                    android:layout_marginBottom="5dp"
                    android:text="@string/set_view_1"
                    android:layout_weight="1"
                    android:soundEffectsEnabled="false"
                    android:onClick="v1Clicked"/>
                <Button
                    android:textSize="10dp"
                    android:textColor="#ffffffff"
                    android:gravity="center"
                    android:id="@+id/button_v1"
                    android:background="#c8000000"
                    android:padding="10dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginTop="5dp"
                    android:layout_marginRight="10dp"
                    android:layout_marginBottom="5dp"
                    android:text="@string/set_view_0"
                    android:layout_weight="1"
                    android:soundEffectsEnabled="false"
                    android:onClick="v0Clicked"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/hsv2"
                android:background="#8cffffff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:weightSum="4"
                android:layout_below="@+id/hsv6"
                android:layout_centerVertical="true">
                <TextView
                    android:textSize="15dp"
                    android:textColor="#ff000000"
                    android:gravity="center"
                    android:id="@+id/tx3"
                    android:padding="10dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="10dp"
                    android:text="@string/set_sounds_title"
                    android:layout_weight="2"
                    android:layout_centerHorizontal="true"/>
                <Button
                    android:textSize="10dp"
                    android:textColor="#ffffffff"
                    android:gravity="center"
                    android:id="@+id/button_s1"
                    android:background="#c8000000"
                    android:padding="10dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginTop="5dp"
                    android:layout_marginRight="10dp"
                    android:layout_marginBottom="5dp"
                    android:text="@string/set_sounds_on"
                    android:layout_weight="1"
                    android:soundEffectsEnabled="false"
                    android:onClick="sOnClicked"/>
                <Button
                    android:textSize="10dp"
                    android:textColor="#ffffffff"
                    android:gravity="center"
                    android:id="@+id/button_s2"
                    android:background="#c8000000"
                    android:padding="10dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginTop="5dp"
                    android:layout_marginRight="10dp"
                    android:layout_marginBottom="5dp"
                    android:text="@string/set_sounds_off"
                    android:layout_weight="1"
                    android:soundEffectsEnabled="false"
                    android:onClick="sOffClicked"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/hsv4"
                android:background="#8cffffff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:weightSum="4"
                android:layout_below="@+id/hsv2"
                android:layout_centerVertical="true">
                <TextView
                    android:textSize="15dp"
                    android:textColor="#ff000000"
                    android:gravity="center"
                    android:id="@+id/tx4"
                    android:padding="10dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="10dp"
                    android:text="@string/set_move_title"
                    android:layout_weight="2"
                    android:layout_centerHorizontal="true"/>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="-10dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginRight="10dp"
                    android:layout_marginBottom="5dp"
                    android:layout_weight="2">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:weightSum="2"
                        android:layout_weight="2">
                        <Button
                            android:textSize="10dp"
                            android:textColor="#ffffffff"
                            android:gravity="center"
                            android:id="@+id/button_pa1"
                            android:background="#c8000000"
                            android:padding="10dp"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginRight="10dp"
                            android:text="@string/set_move_0"
                            android:layout_weight="1"
                            android:soundEffectsEnabled="false"
                            android:onClick="pa0Clicked"/>
                        <Button
                            android:textSize="10dp"
                            android:textColor="#ffffffff"
                            android:gravity="center"
                            android:id="@+id/button_pa2"
                            android:background="#c8000000"
                            android:padding="10dp"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:text="@string/set_move_1"
                            android:layout_weight="1"
                            android:soundEffectsEnabled="false"
                            android:onClick="pa1Clicked"/>
                    </LinearLayout>
                    <Button
                        android:textSize="10dp"
                        android:textColor="#ffffffff"
                        android:gravity="center"
                        android:id="@+id/button_paAlter"
                        android:background="#c8000000"
                        android:padding="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:text="@string/set_move_alter"
                        android:soundEffectsEnabled="false"
                        android:onClick="paAlterClicked"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/hsv5"
                android:background="#8cffffff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:weightSum="4"
                android:layout_below="@+id/hsv4"
                android:layout_centerVertical="true">
                <TextView
                    android:textSize="15dp"
                    android:textColor="#ff000000"
                    android:gravity="center"
                    android:id="@+id/tx5"
                    android:padding="10dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="10dp"
                    android:text="@string/set_helper_title"
                    android:layout_weight="2"
                    android:layout_centerHorizontal="true"/>
                <Button
                    android:textSize="10dp"
                    android:textColor="#ffffffff"
                    android:gravity="center"
                    android:id="@+id/button_h1"
                    android:background="#c8000000"
                    android:padding="10dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginTop="5dp"
                    android:layout_marginRight="10dp"
                    android:layout_marginBottom="5dp"
                    android:text="@string/set_sounds_on"
                    android:layout_weight="1"
                    android:soundEffectsEnabled="false"
                    android:onClick="h0Clicked"/>
                <Button
                    android:textSize="10dp"
                    android:textColor="#ffffffff"
                    android:gravity="center"
                    android:id="@+id/button_h2"
                    android:background="#c8000000"
                    android:padding="10dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginTop="5dp"
                    android:layout_marginRight="10dp"
                    android:layout_marginBottom="5dp"
                    android:text="@string/set_sounds_off"
                    android:layout_weight="1"
                    android:soundEffectsEnabled="false"
                    android:onClick="h1Clicked"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/hsv7"
                android:background="#8cffffff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:weightSum="4"
                android:layout_below="@+id/hsv5"
                android:layout_centerVertical="true">
                <TextView
                    android:textSize="15dp"
                    android:textColor="#ff000000"
                    android:gravity="center"
                    android:id="@+id/tx7"
                    android:padding="10dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="10dp"
                    android:text="@string/set_sp_title"
                    android:layout_weight="2"
                    android:layout_centerHorizontal="true"/>
                <Button
                    android:textSize="10dp"
                    android:textColor="#ffffffff"
                    android:gravity="center"
                    android:id="@+id/button_sp"
                    android:background="@drawable/xml_button_play"
                    android:padding="10dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="-10dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginRight="10dp"
                    android:layout_marginBottom="5dp"
                    android:text="@string/set_sp"
                    android:layout_weight="2"
                    android:soundEffectsEnabled="false"
                    android:onClick="spClicked"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/hsv11"
                android:background="#8cffffff"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:weightSum="4"
                android:layout_below="@+id/hsv7"
                android:layout_centerVertical="true">
                <TextView
                    android:textSize="15dp"
                    android:textColor="#ff000000"
                    android:gravity="center"
                    android:id="@+id/tx11"
                    android:padding="10dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="10dp"
                    android:text="@string/set_ad_title"
                    android:layout_weight="2"
                    android:layout_centerHorizontal="true"/>
                <Button
                    android:textSize="10dp"
                    android:textColor="#ffffffff"
                    android:gravity="center"
                    android:id="@+id/button_ad"
                    android:background="@drawable/xml_button_play"
                    android:padding="10dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="-10dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginRight="10dp"
                    android:layout_marginBottom="5dp"
                    android:text="@string/set_ad"
                    android:layout_weight="2"
                    android:soundEffectsEnabled="false"
                    android:onClick="adClicked"/>
            </LinearLayout>
        </RelativeLayout>
    </ScrollView>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/btns"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:weightSum="12"
        android:layout_alignParentBottom="true"
        android:layout_centerVertical="true">
        <Button
            android:textSize="14dp"
            android:textColor="#ffffffff"
            android:id="@+id/button_set"
            android:background="@drawable/xml_button_play"
            android:padding="15dp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="5dp"
            android:layout_marginBottom="10dp"
            android:text="@string/set_button_back"
            android:layout_weight="8"
            android:soundEffectsEnabled="false"
            android:onClick="backClicked"/>
        <Button
            android:textSize="12dp"
            android:textColor="#ffffffff"
            android:id="@+id/button_rate"
            android:background="@drawable/xml_button_settings"
            android:padding="0dp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="5dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="10dp"
            android:layout_marginBottom="10dp"
            android:text="@string/set_button_rate"
            android:layout_weight="4"
            android:soundEffectsEnabled="false"
            android:onClick="rateClicked"/>
    </LinearLayout>
</RelativeLayout>
