<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android" android:color="#000000">
    <item>
        <vector
            android:height="50dp"
            android:width="50dp"
            android:viewportWidth="300"
            android:viewportHeight="100">
            <group android:name="triableGroup">
                <path
                    android:name="triangle"
                    android:fillColor="#ff2d2d2d"
                    android:pathData="m 45,100 l -45,-50 l 45,-50 l 255,0 l 0,100 z"/>
            </group>
        </vector>
    </item>
</ripple>
