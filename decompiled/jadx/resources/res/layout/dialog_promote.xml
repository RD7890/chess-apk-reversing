<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dialog_alert_root"
    android:background="#ff000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/title_line"
        android:background="#ff000000"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textColor="#ffffffff"
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"/>
        </LinearLayout>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/title_line">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:id="@+id/liner_promote_1"
                android:background="@drawable/xml_button_promote"
                android:clickable="true"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:soundEffectsEnabled="false">
                <View
                    android:id="@+id/promote_1"
                    android:background="@drawable/queen"
                    android:padding="5dp"
                    android:visibility="gone"
                    android:layout_width="45dp"
                    android:layout_height="75dp"/>
                <RelativeLayout
                    android:id="@+id/promote_2d_1"
                    android:visibility="gone"
                    android:layout_width="65dp"
                    android:layout_height="75dp">
                    <TextView
                        android:textColor="#ffffffff"
                        android:id="@+id/textInfo1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="10dp"/>
                    <TextView
                        android:textColor="#ffffffff"
                        android:id="@+id/textInfoBack1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="10dp"/>
                </RelativeLayout>
                <TextView
                    android:textSize="18dp"
                    android:textColor="#ff000000"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="10dp"
                    android:text="@string/queen"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:id="@+id/liner_promote_2"
                android:background="@drawable/xml_button_promote_dark"
                android:clickable="true"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:soundEffectsEnabled="false">
                <View
                    android:id="@+id/promote_2"
                    android:background="@drawable/rook"
                    android:padding="5dp"
                    android:visibility="gone"
                    android:layout_width="45dp"
                    android:layout_height="75dp"/>
                <RelativeLayout
                    android:id="@+id/promote_2d_2"
                    android:visibility="gone"
                    android:layout_width="65dp"
                    android:layout_height="75dp">
                    <TextView
                        android:textColor="#ffffffff"
                        android:id="@+id/textInfo2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="10dp"/>
                    <TextView
                        android:textColor="#ffffffff"
                        android:id="@+id/textInfoBack2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="10dp"/>
                </RelativeLayout>
                <TextView
                    android:textSize="18dp"
                    android:textColor="#ffffffff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="10dp"
                    android:text="@string/rook"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:id="@+id/liner_promote_3"
                android:background="@drawable/xml_button_promote_dark"
                android:clickable="true"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:soundEffectsEnabled="false">
                <View
                    android:id="@+id/promote_3"
                    android:background="@drawable/bishop"
                    android:padding="5dp"
                    android:visibility="gone"
                    android:layout_width="45dp"
                    android:layout_height="75dp"/>
                <RelativeLayout
                    android:id="@+id/promote_2d_3"
                    android:visibility="gone"
                    android:layout_width="65dp"
                    android:layout_height="75dp">
                    <TextView
                        android:textColor="#ffffffff"
                        android:id="@+id/textInfo3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="10dp"/>
                    <TextView
                        android:textColor="#ffffffff"
                        android:id="@+id/textInfoBack3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="10dp"/>
                </RelativeLayout>
                <TextView
                    android:textSize="18dp"
                    android:textColor="#ffffffff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="10dp"
                    android:text="@string/bishop"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:id="@+id/liner_promote_4"
                android:background="@drawable/xml_button_promote"
                android:clickable="true"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:soundEffectsEnabled="false">
                <View
                    android:id="@+id/promote_4"
                    android:background="@drawable/knight"
                    android:padding="5dp"
                    android:visibility="gone"
                    android:layout_width="45dp"
                    android:layout_height="75dp"/>
                <RelativeLayout
                    android:id="@+id/promote_2d_4"
                    android:visibility="gone"
                    android:layout_width="65dp"
                    android:layout_height="75dp">
                    <TextView
                        android:textColor="#ffffffff"
                        android:id="@+id/textInfo4"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="10dp"/>
                    <TextView
                        android:textColor="#ffffffff"
                        android:id="@+id/textInfoBack4"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="10dp"/>
                </RelativeLayout>
                <TextView
                    android:textSize="18dp"
                    android:textColor="#ff000000"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="10dp"
                    android:text="@string/knight"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
